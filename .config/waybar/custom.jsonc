{
  "custom/sys-menu": {
    "format": "<span > </span>",
    "on-click": "omarchy-menu system",
    "on-click-right": "xdg-terminal-exec",
    "tooltip-format": "System Menu\n\nSuper + Esc"
  },
  "custom/vpn": {
    "exec": "$HOME/.config/waybar/scripts/vpn listen",
    "restart-interval": 5,
    "on-click": "$HOME/.config/waybar/scripts/vpn toggle",
    "on-click-right": "mullvad-vpn",
    "return-type": "json"
  }
}
