#!/usr/bin/env bash

# omarchy:summary=Launch Walker and ensure its Elephant data provider is running

if ! systemctl --user is-active -q waybar.service; then
  systemctl --user restart -q elephant.service
fi

# Ensure walker service is running
if ! systemctl --user is-active -q walker.service; then
  systemctl --user restart -q walker.service
fi

exec walker --width 644 --maxheight 300 --minheight 300 "$@"
