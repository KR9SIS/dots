#!/bin/bash

# Launch or focus on a given command identified by the passed in window-pattern.
# Use by some default bindings, like the one for Spotify, to ensure there is only one instance of the application open.

if (($# == 0)); then
  echo "Usage: omarchy-launch-or-focus [window-pattern] [workspace] [launch-command]"
  exit 1
fi

WINDOW_PATTERN="$1"
WORKSPACE="${2:-"-1"}"
LAUNCH_COMMAND="${3:-"uwsm-app -- $WINDOW_PATTERN"}"

echo "$WORKSPACE"
echo "$WINDOW_PATTERN"

WINDOW_ADDRESS=$(hyprctl clients -j | jq -r --arg w "$WORKSPACE" --arg p "$WINDOW_PATTERN" '
  .[] |
  (if ($w | tonumber) == -1 then . else select(.workspace.id == ($w | tonumber)) end) |
  select((.class|test("\\b" + $p + "\\b";"i")) or (.title|test("\\b" + $p + "\\b";"i"))) |
  .address')

echo "$WINDOW_ADDRESS"

if [[ -n $WINDOW_ADDRESS ]]; then
  hyprctl dispatch focuswindow "address:$WINDOW_ADDRESS"
else
  eval exec setsid "$LAUNCH_COMMAND"
fi
